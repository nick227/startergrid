# ── API URL ───────────────────────────────────────────────────────────────────────
# Base URL of the backend API. Baked into the bundle at build time by Vite.
# Leave empty for local dev — the Vite dev server proxies /api to localhost:3000.
# Production: set to your Railway API service URL (e.g. https://api-xxx.up.railway.app)
VITE_API_URL=""

# ── Dev-only ──────────────────────────────────────────────────────────────────────
# These are only active when Vite runs in dev mode (import.meta.env.DEV = true).
# Do NOT set these in a production build environment.

# Enables passwordless operator login in dev. Must match DEV_OPERATOR_ID in the backend .env.
VITE_DEV_OPERATOR_ID="dev-operator"

# Optional comma-separated dealership IDs to scope the dev operator's access.
# Leave blank to allow access to all seeded dealerships.
VITE_DEV_OPERATOR_DEALER_IDS=""
