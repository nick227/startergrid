# ── Core ────────────────────────────────────────────────────────────────────────
# Required. development | production | test
NODE_ENV="development"

# MySQL connection string.
# Local dev (docker-compose): mysql://dealerpoc:dealerpoc@localhost:3307/dealer_onboarding_poc
# Railway production:         provided by the MySQL plugin as ${{MySQL.DATABASE_URL}}
DATABASE_URL="mysql://dealerpoc:dealerpoc@localhost:3307/dealer_onboarding_poc"

# Base URL of this API server. Used for URL validation and future link generation.
# Local dev: http://localhost:3000
# Production: your Railway API service URL (e.g. https://api-xxx.up.railway.app)
APP_BASE_URL="http://localhost:3000"

# ── Auth ─────────────────────────────────────────────────────────────────────────
# REQUIRED in production. Min 32 chars. Generate with: openssl rand -hex 32
SESSION_SECRET=""

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to make credentialed requests.
# Leave empty for local dev (same-origin proxy). Set both frontend URLs in production.
# Example: https://portal-xxx.up.railway.app,https://marketplace-xxx.up.railway.app
ALLOWED_ORIGINS=""

# ── Rate limiting ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Defaults apply in dev/test when not set.
PUBLIC_WRITE_RATE_LIMIT="20"
PUBLIC_WRITE_RATE_WINDOW_MS="60000"

# ── Dispatch ──────────────────────────────────────────────────────────────────────
# Optional. MOCK | SANDBOX | PRODUCTION. Defaults to MOCK behaviour when unset.
DISPATCH_ENVIRONMENT="MOCK"

# ── SMTP (optional) ───────────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true to enable transactional email. All SMTP_* vars are then required.
SMTP_ENABLED="false"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ── Server binding ────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — do not hardcode it on Railway.
# HOST defaults to 0.0.0.0 (bind all interfaces), correct for Railway containers.
PORT="3000"
HOST="0.0.0.0"

# ── Seed (dev / CI only) ──────────────────────────────────────────────────────────
# Used by scripts/dev/seedAdmin to create the initial operator account.
# Defaults apply when unset. Override for reproducible local or CI seeds.
SEED_ADMIN_EMAIL="admin@example.local"
SEED_ADMIN_PASSWORD="dev-change-me"

# ── Dev-only ──────────────────────────────────────────────────────────────────────
# These vars MUST NOT be set in production (env validation will reject them).

# Fallback operator ID when no op_session cookie is present. Enables passwordless dev login.
DEV_OPERATOR_ID="dev-operator"

# Optional comma-separated dealership allowlist for local operator scoping.
# Leave blank to allow the dev operator to access every seeded dealership.
DEV_OPERATOR_DEALER_IDS=""

# ── Geocoding (optional — required for geo:backfill and write-time geocoding) ─────
# Provider: OpenCage (https://opencagedata.com). Free tier: 2 500 req/day.
#
# Verify dealer coordinate coverage (read-only DB report, no provider calls):
#   npm run geo:verify
#   $env:GEO_VERIFY_STRICT="true"; npm run geo:verify
#   $env:GEO_VERIFY_MIN_PERCENT="80"; npm run geo:verify
#
# Backfill missing rooftopLat/rooftopLng (requires OPENCAGE_API_KEY):
#   npm run geo:backfill
#   npm run geo:backfill -- --dry-run
OPENCAGE_API_KEY=""

# ── File paths (optional) ─────────────────────────────────────────────────────────
MOCK_OUTBOX_DIR="./mock-outbox"
FEED_EXPORTS_DIR="./exports"

# ── Upload storage ────────────────────────────────────────────────────────────────
# local (default): writes to ./uploads, served at /uploads/. Fine for dev only —
#   Railway container disks are ephemeral, so uploads vanish on redeploy.
# s3: any S3-compatible object store (AWS S3, Cloudflare R2, MinIO).
#   All S3_* vars below are then required (S3_ENDPOINT required for R2/MinIO,
#   leave empty for AWS S3; S3_REGION defaults to "auto").
STORAGE_DRIVER="local"
S3_BUCKET=""
S3_REGION=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Public URL prefix for stored objects, e.g. https://media.yourdomain.com
# (R2 public bucket URL or CloudFront/S3 website endpoint).
S3_PUBLIC_BASE_URL=""

# ── OAuth provider credentials ────────────────────────────────────────────────────
# Each block covers the platforms listed. Leave blank in dev — mock flows bypass OAuth.
# In production, register an app with each provider and fill in the credentials.

# Meta (meta-automotive-ads, facebook-marketplace-general)
# Meta Developer Console uses "App ID" / "App Secret" — use those names here
META_APP_ID=""
META_APP_SECRET=""

# Google (google-vehicle-ads)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft — covers both Microsoft Advertising (Bing Ads) and LinkedIn Lead Gen Forms
# Register a single Azure AD app; grant both Bing Ads and LinkedIn API permissions.
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# eBay (ebay-motors)
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
EBAY_RUNAME=""                    # RuName from eBay Developer Portal (used as redirect_uri)
EBAY_ENVIRONMENT=""               # "sandbox" for sandbox, leave blank for production
# eBay Sell Inventory (required for listing lifecycle — smoke:ebay-listing)
EBAY_FULFILLMENT_POLICY_ID=""     # From eBay seller account > Business Policies > Shipping
EBAY_PAYMENT_POLICY_ID=""         # From eBay seller account > Business Policies > Payment
EBAY_RETURN_POLICY_ID=""          # From eBay seller account > Business Policies > Returns
EBAY_MERCHANT_LOCATION_KEY=""     # From Sell Account API or Seller Hub (optional on some accounts)

# TikTok (tiktok-automotive-ads)
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""

# Pinterest (pinterest-shopping-ads)
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""

# Reddit (reddit-dynamic-product-ads)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Snapchat (snapchat-dynamic-product-ads)
SNAPCHAT_CLIENT_ID=""
SNAPCHAT_CLIENT_SECRET=""

# X / Twitter (x-dynamic-product-ads) — v2 OAuth2 PKCE app
X_CLIENT_ID=""
X_CLIENT_SECRET=""

# Nextdoor (nextdoor-ads)
NEXTDOOR_CLIENT_ID=""
NEXTDOOR_CLIENT_SECRET=""

# Apple Business Connect (apple-business-connect) — JWT-based ES256 authentication.
# Download the .p8 private key from Apple Developer, store as a single-line PEM.
# Also requires APPLE_KEY_ID (key ID from Apple Developer) and APPLE_TEAM_ID.
APPLE_CLIENT_ID=""
APPLE_PRIVATE_KEY=""
APPLE_KEY_ID=""
APPLE_TEAM_ID=""

# OAuth redirect base URL — used to build callback URLs for all providers.
# Must match the registered redirect URI in each provider's developer console.
# Example: https://api-xxx.up.railway.app
OAUTH_REDIRECT_BASE_URL="http://localhost:3000"
