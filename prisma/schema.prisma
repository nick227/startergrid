generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum BusinessCategory {
  AUTOMOTIVE
  SONGS
  EBOOKS
  WATCHES
  SNEAKERS
  COLLECTIBLES
  APPAREL
  VACATION_RENTALS
  APARTMENTS
  HOMES
  COMMERCIAL_PROPERTY
  BOATS
  TRAILERS_POWERSPORTS_RV
  HEAVY_EQUIPMENT
  FURNITURE
  VIDEO_DISTRIBUTION
}

enum PlatformKind {
  MARKETPLACE
  AD_NETWORK
  SOCIAL_CATALOG
  DEALER_STOREFRONT
  LEAD_ROUTER
}

enum IntegrationClass {
  OWNED              // First-party channel — we build and manage it
  FEEDABLE           // Direct feed/API submission, self-serve
  ASSISTED           // Email/manual handoff required
  PARTNER_DEPENDENT  // External commercial agreement required before activation
}

enum SubmissionMethod {
  MOCK_EMAIL
  MOCK_FORM
  MOCK_API
  FEED_URL
  SFTP
  OAUTH
  MANUAL_REP
}

enum ApplicationStatus {
  NOT_STARTED
  PROFILE_MISSING_INFO
  READY_TO_SUBMIT
  SUBMITTED
  DEALER_ACTION_NEEDED
  PLATFORM_REVIEWING
  APPROVED
  FEED_TESTING
  ACTIVE
  REJECTED
  PAUSED
  PARTNER_REQUIRED
}

enum ValidationStatus {
  PASS
  WARN
  FAIL
}

enum LeadSource {
  DEALER_STOREFRONT
  ADF_XML
  PLATFORM_FORM
  MANUAL
}

enum ChannelEventType {
  VEHICLE_IMPRESSION
  VEHICLE_DETAIL_VIEW
  DEALER_PAGE_VIEW
  INQUIRY_SUBMITTED
  REPORTED_CLICK
  REPORTED_VIEW
  REPORTED_CONTACT
}

enum SourceConfidence {
  OBSERVED_FIRST_PARTY
  PLATFORM_REPORTED
  MANUAL_IMPORTED
  UNAVAILABLE
}

enum VehicleUpdateKind {
  PRICE_CHANGE
  PHOTO_CHANGE
  SOLD
  REMOVED
  RELISTED
  DETAILS_CHANGE
}

enum Environment {
  MOCK
  SANDBOX
  PRODUCTION
}

// ─── Auth enums and models ────────────────────────────────────────────────────

enum OperatorRole {
  SUPER_ADMIN     // Full platform access; no dealer scoping restrictions
  OPERATOR        // Platform access scoped to assigned dealerships
  DEALER_OPERATOR // Read-only access to own dealership data (Phase D — defined now for schema stability)
}

model OperatorAccount {
  id           String       @id @default(cuid())
  email        String       @unique @db.VarChar(255)
  passwordHash String       @db.VarChar(255)
  role         OperatorRole @default(OPERATOR)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sessions     OperatorSession[]
  dealerAccess OperatorDealerAccess[]
}

model OperatorDealerAccess {
  id                String   @id @default(cuid())
  operatorAccountId String
  dealershipId      String
  grantedAt         DateTime @default(now())
  grantedBy         String   @db.VarChar(30) // OperatorAccount.id of the granting account (audit only, loose ref)

  operator   OperatorAccount   @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)
  dealership DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@unique([operatorAccountId, dealershipId])
  @@index([operatorAccountId])
  @@index([dealershipId])
}

model OperatorSession {
  id                String    @id @default(cuid())
  tokenHash         String    @unique @db.VarChar(64) // SHA-256 hex of the raw opaque token
  operatorAccountId String
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  ipAddress         String?   @db.VarChar(45)
  userAgent         String?   @db.VarChar(255)

  account OperatorAccount @relation(fields: [operatorAccountId], references: [id], onDelete: Cascade)

  @@index([operatorAccountId])
  @@index([expiresAt])
}

// ─── Marketplace user models ──────────────────────────────────────────────────
// Separate domain from operator auth. Tokens are not interchangeable.

model MarketplaceUser {
  id           String    @id @default(cuid())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  displayName  String?   @db.VarChar(160)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions  MarketplaceSession[]
  favorites MarketplaceFavorite[]
}

model MarketplaceSession {
  id                String    @id @default(cuid())
  tokenHash         String    @unique @db.VarChar(64) // SHA-256 hex of the raw opaque token
  marketplaceUserId String
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  ipAddress         String?   @db.VarChar(45)
  userAgent         String?   @db.VarChar(255)

  user MarketplaceUser @relation(fields: [marketplaceUserId], references: [id], onDelete: Cascade)

  @@index([marketplaceUserId])
  @@index([expiresAt])
}

model MarketplaceFavorite {
  id                String   @id @default(cuid())
  marketplaceUserId String
  vehicleId         String   // Vehicle.id (listing ID only — VIN is never stored here)
  savedAt           DateTime @default(now())

  user    MarketplaceUser @relation(fields: [marketplaceUserId], references: [id], onDelete: Cascade)
  vehicle Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([marketplaceUserId, vehicleId])
  @@index([marketplaceUserId])
}

// ─── Core models ─────────────────────────────────────────────────────────────

model DealershipProfile {
  id               String           @id @default(cuid())
  legalName        String           @db.VarChar(160)
  dbaName          String?          @db.VarChar(160)
  businessCategory BusinessCategory @default(AUTOMOTIVE)
  dealerLicense    String?          @db.VarChar(80)
  rooftopAddress  Json
  websiteUrl      String?  @db.VarChar(255)
  primaryContact  Json
  inventorySize   Int?
  desiredChannels Json
  documents       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicles                     Vehicle[]
  applications                 PlatformApplication[]
  leads                        Lead[]
  vehicleUpdates               VehicleUpdate[]
  vehicleLifecycleEvents       VehicleLifecycleEvent[]
  subscription                 DealerSubscription?
  inventorySnapshots           InventorySnapshot[]
  readinessRuns                ReadinessRun[]
  generatedArtifacts           GeneratedArtifact[]
  credentialRefs               PlatformCredentialRef[]
  notifications                DealerNotification[]
  syncPolicies                 SyncPolicy[]
  publishQueue                 PublishQueueItem[]
  syncRuns                     SyncRun[]
  syncEvents                   SyncEvent[]
  platformAccounts             PlatformAccount[]
  inventorySources             InventorySource[]
  ingressRuns                  IngressRun[]
  vehiclePerformanceCaches     VehiclePerformanceCache[]
  platformPerformanceSummaries PlatformPerformanceSummary[]
  channelEvents                ChannelEvent[]
  operatorAccess               OperatorDealerAccess[]
}

model Vehicle {
  id              String   @id @default(cuid())
  dealershipId    String
  vin             String   @db.VarChar(32)
  stockNumber     String   @db.VarChar(80)
  year            Int
  make            String   @db.VarChar(80)
  model           String   @db.VarChar(80)
  trim            String?  @db.VarChar(120)
  mileage         Int
  priceCents      Int
  condition       String   @db.VarChar(24)
  exteriorColor   String   @db.VarChar(80)
  interiorColor   String?  @db.VarChar(80)
  bodyStyle       String?  @db.VarChar(80)
  drivetrain      String?  @db.VarChar(80)
  fuelType        String?  @db.VarChar(80)
  transmission    String?  @db.VarChar(80)
  options         Json
  starCore        Json
  categoryPayload Json?
  soldAt          DateTime?
  removedAt       DateTime?
  reactivatedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dealership        DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  media             VehicleMedia[]
  leads             Lead[]
  updates           VehicleUpdate[]
  lifecycleEvents   VehicleLifecycleEvent[]
  queueItems        PublishQueueItem[]
  syncEvents        SyncEvent[]
  performanceCache  VehiclePerformanceCache?
  channelEvents     ChannelEvent[]
  favorites         MarketplaceFavorite[]

  @@index([dealershipId])
  @@unique([dealershipId, stockNumber])
}

model VehicleMedia {
  id          String   @id @default(cuid())
  vehicleId   String
  url         String   @db.VarChar(512)
  kind        String   @db.VarChar(32)
  sortOrder   Int
  width       Int?
  height      Int?
  mimeType    String?  @db.VarChar(80)
  createdAt   DateTime @default(now())

  vehicle     Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

// ─── Platform models ─────────────────────────────────────────────────────────

model PlatformProfile {
  id                       String           @id @default(cuid())
  slug                     String           @unique @db.VarChar(80)
  name                     String           @db.VarChar(140)
  kind                     PlatformKind
  integrationClass         IntegrationClass @default(ASSISTED)
  submissionMethods        Json
  requiredDealershipFields Json
  requiredVehicleFields    Json
  requiredMediaRules       Json
  outputFormat             String           @db.VarChar(80)
  schemaVersion            String           @db.VarChar(80)
  lastVerifiedAt           DateTime?
  profileConfidence        String           @default("MEDIUM") @db.VarChar(24)
  needsReview              Boolean          @default(false)
  sourceNote               String?          @db.Text
  mockEndpoint             String?          @db.VarChar(255)
  integrationUrls          Json?
  sourceUrls               Json
  testFixtures             Json
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  applications             PlatformApplication[]
  validations              MockValidationRun[]
}

model PlatformApplication {
  id            String            @id @default(cuid())
  dealershipId  String
  platformId    String
  status        ApplicationStatus @default(NOT_STARTED)
  referralCode  String?           @db.VarChar(120)
  missingFields Json?
  nextAction    String?           @db.VarChar(255)
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  dealership    DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  platform      PlatformProfile   @relation(fields: [platformId], references: [id], onDelete: Cascade)
  packets       AuthorizationPacket[]
  submissions   SubmissionAttempt[]

  @@unique([dealershipId, platformId])
  @@index([platformId])
}

model AuthorizationPacket {
  id                 String   @id @default(cuid())
  applicationId      String
  authorizationKey   String   @unique @db.VarChar(120)
  scope              Json
  verificationUrl    String   @db.VarChar(512)
  revocationUrl      String   @db.VarChar(512)
  dealershipSnapshot Json
  platformSnapshot   Json
  inventorySnapshot  Json
  packetPayload      Json
  createdAt          DateTime @default(now())
  revokedAt          DateTime?

  application        PlatformApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model SubmissionAttempt {
  id                   String           @id @default(cuid())
  applicationId        String
  method               SubmissionMethod
  destination          String           @db.VarChar(255)
  subject              String?          @db.VarChar(255)
  payload              Json
  status               ValidationStatus @default(PASS)
  response             Json?
  receiptJson          Json?
  mockAccepted         Boolean          @default(false)
  rejectionReasonsJson Json?
  artifactPath         String?          @db.VarChar(512)
  environment          Environment      @default(MOCK)
  createdAt            DateTime         @default(now())

  application          PlatformApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model MockValidationRun {
  id                  String           @id @default(cuid())
  platformId          String
  status              ValidationStatus
  overallStatus       String?          @db.VarChar(24)
  summary             String           @db.VarChar(255)
  results             Json
  platformResultsJson Json?
  createdAt           DateTime         @default(now())

  platform            PlatformProfile @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([platformId])
}

// ─── Business value models ────────────────────────────────────────────────────

model Lead {
  id              String     @id @default(cuid())
  dealershipId    String
  vehicleId       String?
  source          LeadSource
  platformSlug    String     @db.VarChar(80)
  contactName     String?    @db.VarChar(160)
  contactEmail    String?    @db.VarChar(255)
  contactPhone    String?    @db.VarChar(40)
  message         String?    @db.Text
  vehicleInterest Json?
  adfPayload      Json?
  createdAt       DateTime   @default(now())

  dealership      DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicle         Vehicle?          @relation(fields: [vehicleId], references: [id])

  @@index([dealershipId])
  @@index([platformSlug])
}

model VehicleUpdate {
  id             String            @id @default(cuid())
  vehicleId      String
  dealershipId   String
  kind           VehicleUpdateKind
  previousValue  Json?
  newValue       Json?
  propagatedTo   Json?
  createdAt      DateTime          @default(now())

  vehicle        Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  dealership     DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([dealershipId])
}

model VehicleLifecycleEvent {
  id              String   @id @default(cuid())
  vehicleId       String
  dealershipId    String
  fromState       String   @db.VarChar(20)
  toState         String   @db.VarChar(20)
  triggerKind     String   @db.VarChar(40)
  source          String   @db.VarChar(40)
  ingressRunId    String?
  statusChangedAt DateTime
  note            String?  @db.VarChar(255)
  createdAt       DateTime @default(now())

  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  dealership      DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([dealershipId, createdAt])
  @@index([ingressRunId])
}

model DealerSubscription {
  id               String    @id @default(cuid())
  dealershipId     String    @unique
  plan             String    @db.VarChar(40)
  setupFeeCents    Int       @default(0)
  monthlyFeeCents  Int       @default(0)
  activeFrom       DateTime  @default(now())
  activeTo         DateTime?
  status           String    @db.VarChar(24)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  dealership       DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
}

// ─── Phase 5 models ───────────────────────────────────────────────────────────

model PlatformProfileVersion {
  id            String   @id @default(cuid())
  platformSlug  String   @db.VarChar(80)
  schemaVersion String   @db.VarChar(80)
  profileJson   Json
  checksum      String   @db.VarChar(64)
  seededAt      DateTime @default(now())

  @@index([platformSlug])
}

model InventorySnapshot {
  id            String   @id @default(cuid())
  dealershipId  String
  vehicleCount  Int
  snapshotJson  Json
  checksum      String   @db.VarChar(64)
  createdAt     DateTime @default(now())

  dealership    DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  readinessRuns ReadinessRun[]

  @@index([dealershipId])
}

model ReadinessRun {
  id                  String      @id @default(cuid())
  dealershipId        String
  inventorySnapshotId String
  environment         Environment @default(MOCK)
  runMode             String      @db.VarChar(24)
  overallStatus       String      @db.VarChar(24)
  greenCount          Int
  yellowCount         Int
  redCount            Int
  validatorVersion    String      @db.VarChar(40)
  resultsJson         Json
  createdAt           DateTime    @default(now())

  dealership          DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  inventorySnapshot   InventorySnapshot @relation(fields: [inventorySnapshotId], references: [id], onDelete: Cascade)
  artifacts           GeneratedArtifact[]

  @@index([dealershipId])
}

model GeneratedArtifact {
  id                 String      @id @default(cuid())
  dealershipId       String
  platformSlug       String      @db.VarChar(80)
  format             String      @db.VarChar(80)
  filename           String      @db.VarChar(255)
  storagePath        String      @db.VarChar(512)
  checksum           String      @db.VarChar(64)
  sizeBytes          Int
  environment        Environment @default(MOCK)
  linkedRunId        String?
  linkedSubmissionId String?
  expiresAt          DateTime?
  createdAt          DateTime    @default(now())

  dealership         DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  readinessRun       ReadinessRun?     @relation(fields: [linkedRunId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([platformSlug])
}

model PlatformCredentialRef {
  id              String      @id @default(cuid())
  platformSlug    String      @db.VarChar(80)
  dealershipId    String?
  environment     Environment
  credentialKey   String      @db.VarChar(255)
  expiresAt       DateTime?
  lastValidatedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  dealership      DealershipProfile? @relation(fields: [dealershipId], references: [id], onDelete: SetNull)

  @@index([platformSlug])
}

model DealerNotification {
  id             String    @id @default(cuid())
  dealershipId   String
  type           String    @db.VarChar(60)
  payload        Json
  deliveryStatus String    @default("PENDING") @db.VarChar(20)
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())

  dealership   DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
}

// ─── Event + Publishing Control models ───────────────────────────────────────

enum SyncMode {
  REAL_TIME          // Immediate publish when valid
  SCHEDULED          // Batch on schedule
  MANUAL             // Operator-triggered only
  APPROVAL_REQUIRED  // Needs operator sign-off before publish
}

enum PublishQueueStatus {
  READY           // Cleared by policy; will publish on next sync run
  BLOCKED         // Waiting on partner/manual action
  NEEDS_APPROVAL  // Policy requires operator approval before dispatch
  SCHEDULED       // In queue for future scheduled run
  CLAIMED         // Atomically locked by a scheduler instance; in-flight
  HELD            // Operator placed item on hold pending further review
  SENT            // Dispatched (MOCK env: recorded, not real API)
  FAILED          // All retry attempts exhausted
  CANCELLED       // Superseded by newer change or manually cancelled
}

enum SyncEventKind {
  INVENTORY_CHANGE   // Price/photo/details changed
  VEHICLE_SOLD       // Vehicle marked sold — urgent removal
  VEHICLE_REMOVED    // Vehicle removed from inventory
  ARTIFACT_GENERATED // Feed file created
  SUBMISSION_SENT    // Submission attempt dispatched
  APPROVAL_GRANTED   // Operator approved a queue item
  APPROVAL_REJECTED  // Operator rejected a queue item
  PARTNER_FOLLOWUP   // Partner action recorded
  ACCOUNT_UPDATED    // PlatformAccount state changed
  POLICY_CHANGED     // SyncPolicy updated
  DISPATCH_CLAIMED    // Scheduler atomically claimed item for dispatch
  DISPATCH_FAILED     // Dispatch attempt failed; may retry
  DISPATCH_RETRY      // Item requeued for retry with backoff
  APPROVAL_REQUESTED  // Item entered NEEDS_APPROVAL state
  APPROVAL_HELD       // Operator placed item on hold
  APPROVAL_RELEASED   // Operator released item from hold
  INVENTORY_IMPORT    // Bulk CSV/paste import batch completed
}

enum PlatformAccountState {
  ACCOUNT_NEEDED      // No account exists yet
  CREDENTIALS_NEEDED  // Account exists but no valid credentials
  PENDING_REVIEW      // Application submitted, awaiting platform review
  ACTIVE              // Account operational and publishing
  BLOCKED             // Account suspended or restricted
  PARTNER_REQUIRED    // Needs commercial agreement before activation
  SUSPENDED           // Operator-suspended
}

model SyncPolicy {
  id                 String    @id @default(cuid())
  dealershipId       String
  platformSlug       String    @db.VarChar(80)
  mode               SyncMode
  urgentRemoval      Boolean   @default(true)  // bypass cooldown/mode for SOLD/REMOVED
  scheduleHint       String?   @db.VarChar(80) // e.g. "DAILY_09:00", "HOURLY"
  minIntervalMinutes Int?                       // min minutes between dispatches; null = platform-governed
  lastDispatchedAt   DateTime?                  // updated on each successful dispatch
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  dealership    DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, platformSlug])
  @@index([dealershipId])
}

model PublishQueueItem {
  id             String             @id @default(cuid())
  dealershipId   String
  vehicleId      String?
  platformSlug   String             @db.VarChar(80)
  triggerKind    String             @db.VarChar(40)  // VehicleUpdateKind
  status         PublishQueueStatus @default(READY)
  policyMode     SyncMode
  priority       Int                @default(5)      // 1=urgent, 10=low
  idempotencyKey String             @unique @default(cuid()) @db.VarChar(120)
  scheduledFor   DateTime?
  approvalRequiredReason String?    @db.VarChar(255)
  blockReason    String?            @db.VarChar(255)
  approvedBy     String?            @db.VarChar(160)
  approvedAt     DateTime?
  rejectedBy     String?            @db.VarChar(160)
  rejectedAt     DateTime?
  rejectionReason String?           @db.Text
  heldBy         String?            @db.VarChar(160)
  heldAt         DateTime?
  holdReason     String?            @db.Text
  sentAt         DateTime?
  failureReason  String?            @db.Text
  claimedAt      DateTime?
  claimedBy      String?            @db.VarChar(120)
  attemptCount   Int                @default(0)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  dealership     DealershipProfile  @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([dealershipId, status])
  @@index([dealershipId, vehicleId, platformSlug])
  @@index([vehicleId])
}

model SyncRun {
  id           String    @id @default(cuid())
  dealershipId String
  triggeredBy  String    @db.VarChar(80)
  status       String    @db.VarChar(24) @default("PENDING")
  itemsTotal   Int       @default(0)
  itemsSent    Int       @default(0)
  itemsFailed  Int       @default(0)
  itemsSkipped Int       @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  dealership   DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  events       SyncEvent[]

  @@index([dealershipId])
}

model SyncEvent {
  id           String        @id @default(cuid())
  dealershipId String
  vehicleId    String?
  platformSlug String?       @db.VarChar(80)
  kind         SyncEventKind
  payload      Json
  syncRunId    String?
  createdAt    DateTime      @default(now())

  dealership   DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  syncRun      SyncRun?          @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([vehicleId])
  @@index([kind])
}

// ─── Inventory Ingress models ─────────────────────────────────────────────────

enum InventorySourceKind {
  API
  WEBHOOK
  CSV
  JSON
  MANUAL
  SCHEDULED_CHECK
}

enum InventorySourceStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
  ERROR
}

enum IngressRunStatus {
  RECEIVED
  PROCESSING
  COMMITTED
  PARTIAL
  FAILED
}

model InventorySource {
  id             String                @id @default(cuid())
  dealershipId   String
  slug           String                @db.VarChar(80)
  label          String                @db.VarChar(160)
  kind           InventorySourceKind
  status         InventorySourceStatus @default(ACTIVE)
  lastReceivedAt DateTime?
  lastCheckedAt  DateTime?
  configJson     Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  dealership  DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  ingressRuns IngressRun[]

  @@unique([dealershipId, slug])
  @@index([dealershipId])
}

model IngressRun {
  id                 String          @id @default(cuid())
  dealershipId       String
  sourceId           String?
  sourceKind         InventorySourceKind
  status             IngressRunStatus @default(RECEIVED)
  receivedAt         DateTime
  completedAt        DateTime?
  vehicleCount       Int             @default(0)
  createdCount       Int             @default(0)
  updatedCount       Int             @default(0)
  skippedCount       Int             @default(0)
  blockedCount       Int             @default(0)
  errorCount         Int             @default(0)
  mappingJson        Json?
  summaryJson        Json?
  platformImpactJson Json?
  createdAt          DateTime        @default(now())

  dealership DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  source     InventorySource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([sourceId])
}

model PlatformAccount {
  id                String               @id @default(cuid())
  dealershipId      String
  platformSlug      String               @db.VarChar(80)
  state             PlatformAccountState @default(ACCOUNT_NEEDED)
  accountId         String?              @db.VarChar(120)
  platformRepName   String?              @db.VarChar(160)
  platformRepEmail  String?              @db.VarChar(255)
  membershipStatus  String?              @db.VarChar(80)
  nextAction        String?              @db.VarChar(255)
  nextActionOwner   String?              @db.VarChar(80)
  notes             String?              @db.Text
  lastChecked       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  dealership   DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, platformSlug])
  @@index([dealershipId])
}

// ─── Performance engine cache models ─────────────────────────────────────────
//
// Performance cache tables are written by aggregate jobs and read by performance
// API endpoints. Jobs compute from Vehicle, SyncEvent, and Lead data.
//
// Language contract: all platform data uses "observed assist" framing —
// never "sold by". Confidence levels gate how results are labelled.

model VehiclePerformanceCache {
  id                String   @id @default(cuid())
  dealershipId      String
  vehicleId         String   @unique
  stockNumber       String   @db.VarChar(80)
  make              String   @db.VarChar(80)
  model             String   @db.VarChar(80)
  year              Int
  priceCents        Int
  condition         String   @db.VarChar(10)
  daysOnline        Int
  firstListedAt     DateTime
  comparableCount      Int      @default(0)
  avgComparableDays    Float?
  medianComparableDays Float?                              // median days for sold comparables
  benchmarkConfidence  String   @db.VarChar(16) @default("INSUFFICIENT")  // INSUFFICIENT|LOW|MEDIUM|HIGH
  movementSignal       String   @db.VarChar(16)            // FAST|ON_TRACK|SLOW|STALE|LOW_DATA
  platformAssistsJson Json?                    // { [slug]: { leads: number } }
  computedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dealership  DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, movementSignal])
}

model PlatformPerformanceSummary {
  id               String   @id @default(cuid())
  dealershipId     String
  platformSlug     String   @db.VarChar(80)
  vehiclesListed   Int      @default(0)
  vehiclesSold     Int      @default(0)
  vehiclesRemoved  Int      @default(0)
  avgDaysToMove    Float?
  medianDaysToMove Float?
  avgDaysOnPlatform Float?
  totalLeads       Int      @default(0)
  leadsPerVehicle  Float?
  confidence       String   @db.VarChar(16)  // INSUFFICIENT|LOW|MEDIUM|HIGH
  sampleSize       Int      @default(0)
  channelMetricsJson Json?
  computedAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dealership  DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, platformSlug])
  @@index([dealershipId])
}

// ─── Channel measurement ─────────────────────────────────────────────────────
// Neutral engagement events for any platform/channel slug.
// Marketplace writes observed_first_party events; partner imports use platform_reported.

model ChannelEvent {
  id               String             @id @default(cuid())
  dealershipId     String
  platformSlug     String             @db.VarChar(80)
  vehicleId        String?
  listingId        String?            @db.VarChar(80)
  eventType        ChannelEventType
  sourceConfidence SourceConfidence
  quantity         Int                @default(1)
  metadataJson     Json?
  occurredAt       DateTime           @default(now())
  createdAt        DateTime           @default(now())

  dealership DealershipProfile @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([dealershipId, platformSlug])
  @@index([dealershipId, platformSlug, eventType])
  @@index([vehicleId])
  @@index([occurredAt])
}
