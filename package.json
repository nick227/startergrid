{
  "name": "auto-dealer-onboarding-poc-v1",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "V4: DEALER_STOREFRONT owned channel, real feed artifacts, vehicle update propagation, lead capture, dealer-facing status copy, MySQL lifecycle persistence, 18 platforms.",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run -s build && node --test dist/src/tests/*.test.js",

    "dealer:create":         "npm run -s build && node dist/src/scripts/dealer/dealerCreate.js",
    "dealer:create:pristine":"npm run -s build && node dist/src/scripts/dealer/dealerCreate.js --use-pristine",
    "dealer:status":         "npm run -s build && node dist/src/scripts/dealer/dealerStatus.js",
    "dealer:proof":          "npm run -s build && node dist/src/scripts/dealer/dealerProof.js",
    "dealer:invoice":        "npm run -s build && node dist/src/scripts/dealer/dealerInvoice.js",
    "dealer:export":         "npm run -s build && node dist/src/scripts/dealer/dealerExport.js",
    "vehicle:update":        "npm run -s build && node dist/src/scripts/dealer/vehicleUpdate.js",
    "ingest:json:fixture":   "npm run -s build && node dist/src/scripts/inventory/ingestJsonFixture.js",
    "ingress:check-source":  "npm run -s build && node dist/src/scripts/inventory/checkSource.js",
    "ingress:poll-sources":  "npm run -s build && node dist/src/scripts/inventory/pollSources.js",

    "publish:prepare":       "npm run -s build && node dist/src/scripts/sync/publishPrepare.js",
    "sync:scheduler":        "npm run -s build && node dist/src/scripts/sync/syncScheduler.js",
    "sync:approval":         "npm run -s build && node dist/src/scripts/sync/syncApproval.js",
    "sync:queue":            "npm run -s build && node dist/src/scripts/sync/syncQueue.js",
    "sync:run":              "npm run -s build && node dist/src/scripts/sync/syncRun.js",

    "validate":              "npm run -s build && node dist/src/scripts/dev/validateAll.js",
    "validate:pristine":     "npm run -s build && node dist/src/scripts/dev/validatePristine.js",
    "validate:pristine:db":  "npm run -s build && node dist/src/scripts/dev/validatePristine.js --db",
    "smoke:test":            "npm run -s build && node dist/src/scripts/dev/smokeTest.js",
    "performance:compute":         "npm run -s build && node dist/src/scripts/performance/computePerformance.js",
    "demo:reset":                 "npm run -s build && node dist/src/scripts/dev/demoReset.js",
    "demo:connected-inventory":   "npm run -s build && node dist/src/scripts/dev/connectedInventoryDemo.js",
    "report":                "npm run -s build && node dist/src/scripts/dev/report.js",
    "onboard:fake":          "npm run -s build && node dist/src/scripts/dev/fakeOnboard.js",
    "submit:fake":           "npm run -s build && node dist/src/scripts/dev/fakeSubmitAll.js",

    "poc:green":             "npm run -s build && node dist/src/scripts/poc/pocGreen.js",
    "poc:risk":              "npm run -s build && node dist/src/scripts/poc/pocRiskMatrix.js",
    "poc:strict":            "npm run -s poc:risk",
    "poc:portal":            "npm run -s build && node dist/src/scripts/poc/pocPortalLifecycle.js",
    "poc:v4":                "npm run -s build && node dist/src/scripts/poc/pocPortalLifecycle.js",

    "server:start":          "npm run -s build && node dist/src/scripts/server.js",

    "db:generate":           "prisma generate",
    "db:push":               "prisma db push",
    "db:seed":               "npm run -s build && node dist/prisma/seed.js",
    "db:reset":              "prisma db push --force-reset && npm run db:seed",
    "db:seed:versions":      "npm run -s build && node dist/prisma/seed.js",

    "ui:install":            "npm install --prefix apps/web",
    "ui:dev":                "npm run client:generate && npm run dev --prefix apps/web",
    "ui:build":              "npm run client:generate && npm run build --prefix apps/web",
    "ui:lint":               "npm run lint --prefix apps/web",
    "ui:lint:fix":           "npm run lint:fix --prefix apps/web",

    "openapi:validate":      "redocly lint openapi/openapi.yaml",
    "client:generate":       "node node_modules/openapi-typescript-codegen/bin/index.js --input openapi/openapi.yaml --output packages/api-client/generated --client fetch --useOptions --exportCore true"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "dotenv": "latest",
    "fastify": "^5.8.5",
    "jszip": "latest",
    "nanoid": "latest",
    "nodemailer": "latest",
    "tsx": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.0",
    "@types/node": "latest",
    "@types/nodemailer": "latest",
    "openapi-typescript-codegen": "^0.29.0",
    "prisma": "^6",
    "typescript": "latest"
  }
}
